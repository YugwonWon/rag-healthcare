# ========================================
# 맥미니 로컬 배포용 환경설정
# Cloud Run 대체 → Mac Mini M4 상시 서버
# ========================================
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요.
# deploy_local.sh는 .env.local을 우선 로드합니다.

# ----------------------------------------
# LLM 설정 (Ollama - Mac Mini 네이티브)
# ----------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=kanana-counseling

# Mac Mini M4의 Metal GPU 활용으로 Cloud Run 대비 2-3배 빠름
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=512

# ----------------------------------------
# 임베딩 설정 (Apple Metal 가속)
# ----------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
# mps = Apple Metal Performance Shaders (GPU 가속)
# M4 Neural Engine은 Ollama가 자동 활용
EMBEDDING_DEVICE=mps

# ----------------------------------------
# PostgreSQL + pgvector (Cloud SQL 유지)
# ----------------------------------------
# 방법 1: 직접 TCP 연결 (Cloud SQL 공개 IP 사용 시)
# Cloud SQL 콘솔 → 연결 → 공개IP 추가 → 현재 맥미니 IP 허용
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@CLOUD_SQL_PUBLIC_IP:5432/healthcare

# 방법 2: Cloud SQL Auth Proxy 사용 (보안 권장)
# brew install cloud-sql-proxy
# CLOUD_SQL_INSTANCE=rag-healthcare-483412:asia-northeast3:healthcare-db
# DB_PROXY_PORT=5432
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/healthcare

# ----------------------------------------
# Neo4j (클라우드 Aura 유지)
# ----------------------------------------
GRAPHRAG_ENABLED=true
NEO4J_URI=neo4j+s://uuid.databases.neo4j.io
NEO4J_USERNAME=your-neo4j-username-here
NEO4J_PASSWORD=your-neo4j-password-here

# ----------------------------------------
# ngrok Tunnel (외부 접근용 - 무료 고정 도메인)
# ----------------------------------------
NGROK_DOMAIN=acronymous-nonobsessive-chong.ngrok-free.dev

# ----------------------------------------
# 기타 설정
# ----------------------------------------
DEBUG=false
API_PORT=8000
